# Microsoft Entra app registration used by the SPA
VITE_AZURE_CLIENT_ID=<YOUR_ENTRA_CLIENT_ID>
VITE_AZURE_TENANT_ID=<YOUR_AZURE_TENANT_ID>

# Backend base URL for API and SignalR traffic
VITE_BACKEND_URL=http://localhost:5113

# If your API uses a separate app registration, set its exposed scope here.
# If omitted, the frontend defaults to api://<VITE_AZURE_CLIENT_ID>/access_as_user
VITE_BACKEND_SCOPE=api://<YOUR_ENTRA_CLIENT_ID>/access_as_user
